{
  "name": "eterna-browser-agent",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Eterna AI external Playwright Browser Agent — investigates public pages, captures evidence, discovers public contacts.",
  "main": "src/server.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "build": "tsc -p tsconfig.json",
    "postinstall": "playwright install --with-deps chromium"
  },
  "dependencies": {
    "express": "^4.19.2",
    "playwright": "^1.47.0",
    "zod": "^3.23.8",
    "tsx": "^4.19.1",
    "uuid": "^10.0.0",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/cors": "^2.8.17",
    "@types/node": "^20.14.0",
    "@types/uuid": "^10.0.0",
    "typescript": "^5.5.4"
  }
}
